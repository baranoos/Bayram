# PostgreSQL (Supabase → Project Settings → Database → Connection string)
# Encode special characters in the password, e.g. ! becomes %21
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require"

AUTH_JWT_SECRET="generate-a-random-uuid"

SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="uploads"
NEXT_PUBLIC_USE_SUPABASE=1
